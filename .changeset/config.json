{
	"$schema": "https://unpkg.com/@changesets/config@3.1.1/schema.json",
	"changelog": [
		"@savvy-web/changelog",
		{
			"repo": "spencerbeggs/rspress-plugin-api-extractor",
			"packages": {
				"rspress-plugin-api-extractor": {
					"additionalScopes": ["plugin/**"],
					"versionFiles": [
						{
							"glob": "plugin/.claude-plugin/plugin.json",
							"paths": ["$.version"]
						}
					]
				}
			}
		}
	],
	"commit": false,
	"access": "restricted",
	"baseBranch": "main",
	"updateInternalDependencies": "patch",
	"ignore": ["@sites/*", "@modules/*"],
	"privatePackages": {
		"tag": true,
		"version": true
	}
}
