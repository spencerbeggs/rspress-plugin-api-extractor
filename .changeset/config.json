{
	"$schema": "https://unpkg.com/@changesets/config@3.1.1/schema.json",
	"changelog": [
		"@savvy-web/changesets/changelog",
		{
			"repo": "spencerbeggs/rspress-plugin-api-extractor"
		}
	],
	"commit": false,
	"access": "restricted",
	"baseBranch": "main",
	"updateInternalDependencies": "patch",
	"ignore": ["versioned-v1", "versioned-v2", "kitchensink", "basic", "versioned", "i18n", "multi"],
	"privatePackages": {
		"tag": true,
		"version": true
	}
}
