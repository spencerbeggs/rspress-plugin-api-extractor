{
	"name": "rspress-plugin-api-extractor-monorepo",
	"version": "0.0.0",
	"private": true,
	"description": "Monorepo for rspress-plugin-api-extractor plugin development",
	"homepage": "https://github.com/spencerbeggs/rspress-plugin-api-extractor#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/rspress-plugin-api-extractor.git"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"type": "module",
	"scripts": {
		"build": "turbo run build:dev build:prod --log-order=grouped --output-logs=full --log-prefix=none",
		"build:basic": "turbo run build:dev build:prod --filter=@sites/basic --ui=stream",
		"build:multi": "turbo run build:dev build:prod --filter=@sites/multi --ui=stream",
		"ci:build": "CI=\"true\" turbo run build:dev build:prod --filter=rspress-plugin-api-extractor --log-order=grouped --output-logs=full --log-prefix=none",
		"ci:test": "CI=\"true\" vitest run --coverage",
		"ci:version": "savvy-changesets version && biome format --write .",
		"commit:check": "savvy-commit check",
		"commit:init": "savvy-commit init",
		"dev": "turbo run dev --filter=@sites/basic",
		"dev:basic": "turbo run dev --filter=@sites/basic",
		"dev:i18n": "turbo run dev --filter=@sites/i18n",
		"dev:multi": "turbo run dev --filter=@sites/multi",
		"dev:versioned": "turbo run dev --filter=@sites/versioned",
		"lint": "biome check --max-diagnostics=none",
		"lint:fix": "biome check --write --max-diagnostics=none",
		"lint:fix:unsafe": "biome check --write --unsafe --max-diagnostics=none",
		"lint:md": "markdownlint-cli2 '**/*.{md,mdx}' --config './lib/configs/.markdownlint-cli2.jsonc'",
		"lint:md:fix": "markdownlint-cli2  --config './lib/configs/.markdownlint-cli2.jsonc' --fix",
		"prepare": "husky",
		"preview": "turbo run preview --filter=@sites/basic",
		"preview:basic": "turbo run preview --filter=@sites/basic",
		"preview:i18n": "turbo run preview --filter=@sites/i18n",
		"preview:multi": "turbo run preview --filter=@sites/multi",
		"preview:versioned": "turbo run preview --filter=@sites/versioned",
		"reset": "node lib/scripts/hard-reset.mts",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest --watch",
		"typecheck": "turbo run types:check --log-prefix=none --log-order=grouped"
	},
	"devDependencies": {
		"@savvy-web/changesets": "^0.10.0",
		"@savvy-web/commitlint": "^0.9.1",
		"@savvy-web/lint-staged": "^1.1.0",
		"@savvy-web/vitest": "^1.3.2"
	},
	"packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800",
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "10.33.4",
			"onFail": "ignore"
		},
		"runtime": [
			{
				"name": "node",
				"version": "26.2.0",
				"onFail": "ignore"
			}
		]
	}
}
