{
	"name": "rspress-plugin-api-extractor-monorepo",
	"version": "0.0.0",
	"private": true,
	"description": "Monorepo for rspress-plugin-api-extractor plugin development",
	"homepage": "https://github.com/spencerbeggs/rspress-plugin-api-extractor#readme",
	"repository": {
		"type": "git",
		"url": "https://github.com/spencerbeggs/rspress-plugin-api-extractor.git"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"type": "module",
	"scripts": {
		"build": "turbo run build --filter='./plugin' --filter='./modules/*' --log-order=grouped",
		"build:basic": "turbo run build --filter=basic --ui=stream",
		"build:multi": "turbo run build --filter=multi --ui=stream",
		"ci:build": "CI=\"true\" turbo run build --filter='./plugin' --filter='./modules/*' --log-order=grouped --output-logs=full",
		"ci:test": "CI=\"true\" vitest run --coverage",
		"ci:version": "savvy-changesets version && biome format --write .",
		"commit:check": "savvy-commit check",
		"commit:init": "savvy-commit init",
		"dev": "turbo run dev --filter=basic",
		"dev:basic": "turbo run dev --filter=basic",
		"dev:i18n": "turbo run dev --filter=i18n",
		"dev:multi": "turbo run dev --filter=multi",
		"dev:versioned": "turbo run dev --filter=versioned",
		"lint": "biome check --max-diagnostics=none",
		"lint:fix": "biome check --write --max-diagnostics=none",
		"lint:fix:unsafe": "biome check --write --unsafe --max-diagnostics=none",
		"lint:md": "markdownlint-cli2 '**/*.{md,mdx}' --config './lib/configs/.markdownlint-cli2.jsonc'",
		"lint:md:fix": "markdownlint-cli2  --config './lib/configs/.markdownlint-cli2.jsonc' --fix",
		"prepare": "husky",
		"preview": "turbo run preview --filter=basic",
		"preview:basic": "turbo run preview --filter=basic",
		"preview:i18n": "turbo run preview --filter=i18n",
		"preview:multi": "turbo run preview --filter=multi",
		"preview:versioned": "turbo run preview --filter=versioned",
		"reset": "node --experimental-strip-types --experimental-transform-types lib/scripts/hard-reset.mts",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest --watch",
		"typecheck": "turbo run types:check --log-prefix=none --log-order=grouped"
	},
	"devDependencies": {
		"@savvy-web/changesets": "^0.8.0",
		"@savvy-web/commitlint": "^0.6.0",
		"@savvy-web/lint-staged": "^0.8.0",
		"@savvy-web/vitest": "^1.3.1"
	},
	"packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "10.33.0",
			"onFail": "ignore"
		},
		"runtime": [
			{
				"name": "node",
				"version": "24.11.0",
				"onFail": "ignore"
			}
		]
	}
}
