{
	"$schema": "https://turborepo.com/schema.v2.json",
	"extends": ["//"],
	"tasks": {
		"build": {
			"cache": false,
			"dependsOn": ["^build:meta"],
			"outputLogs": "full",
			"outputs": ["dist/**"]
		},
		"dev": {
			"cache": false,
			"dependsOn": [],
			"persistent": true
		},
		"preview": {
			"cache": false,
			"dependsOn": ["build"],
			"persistent": true
		}
	}
}
