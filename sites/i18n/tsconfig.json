{
	"$schema": "https://json.schemastore.org/tsconfig.json",
	"compilerOptions": {
		"jsx": "react-jsx",
		"lib": ["DOM", "ES2020"],
		"module": "esnext",
		"moduleResolution": "bundler",
		"skipLibCheck": true,
		"strict": true,
		"target": "ES2020"
	},
	"exclude": ["node_modules", "dist"],
	"include": ["*.ts", "docs/**/*.mdx"]
}
