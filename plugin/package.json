{
	"name": "rspress-plugin-api-extractor",
	"version": "0.1.0",
	"private": true,
	"description": "RSPress plugin for generating API documentation from TypeScript API Extractor models",
	"keywords": ["rspress", "plugin", "api-extractor", "documentation", "typescript"],
	"homepage": "https://github.com/spencerbeggs/rspress-plugin-api-extractor#readme",
	"repository": {
		"type": "git",
		"url": "https://github.com/spencerbeggs/rspress-plugin-api-extractor.git",
		"directory": "plugin"
	},
	"license": "MIT",
	"author": "Spencer Beggs",
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./runtime": "./src/runtime/index.tsx"
	},
	"files": ["dist", "src/runtime"],
	"scripts": {
		"build": "turbo run build:dev build:prod",
		"build:dev": "rslib build --config-loader native --env-mode dev",
		"build:prod": "rslib build --config-loader native --env-mode npm",
		"types:check": "tsgo --noEmit"
	},
	"dependencies": {
		"@effect/platform": "catalog:silk",
		"@effect/platform-node": "catalog:silk",
		"@effect/sql": "catalog:silk",
		"@effect/sql-sqlite-node": "catalog:silk",
		"@microsoft/api-extractor-model": "^7.33.8",
		"@shikijs/twoslash": "^4.0.2",
		"clsx": "^2.1.1",
		"effect": "catalog:silk",
		"gray-matter": "^4.0.3",
		"hast-util-to-jsx-runtime": "^2.3.6",
		"image-size": "^2.0.2",
		"mdast-util-from-markdown": "^2.0.2",
		"mdast-util-to-hast": "^13.2.1",
		"prettier": "^3.8.3",
		"react-markdown": "^10.1.0",
		"semver-effect": "^0.2.1",
		"shiki": "^4.0.2",
		"type-registry-effect": "^0.2.2",
		"typescript": "catalog:silk"
	},
	"devDependencies": {
		"@microsoft/tsdoc": "^0.16.0",
		"@rslib/core": "^0.21.3",
		"@rspress/core": "^2.0.9",
		"@savvy-web/rslib-builder": "^0.20.3",
		"@types/hast": "^3.0.4",
		"@types/mdast": "^4.0.4",
		"@types/node": "catalog:silk",
		"@types/react": "catalog:silk",
		"@types/react-dom": "catalog:silk",
		"@types/unist": "^3.0.3",
		"@typescript/native-preview": "catalog:silk",
		"mdast-util-mdx-jsx": "^3.2.0",
		"react": "catalog:silk",
		"react-dom": "catalog:silk",
		"sass": "^1.99.0",
		"unified": "^11.0.5",
		"unist-util-visit": "^5.1.0"
	},
	"peerDependencies": {
		"@rspress/core": "^2.0.0",
		"react": "catalog:silkPeers",
		"react-dom": "catalog:silkPeers"
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev",
		"linkDirectory": true,
		"targets": [
			{
				"protocol": "npm",
				"registry": "https://npm.pkg.github.com/",
				"directory": "dist/github",
				"access": "public",
				"provenance": true
			},
			{
				"protocol": "npm",
				"registry": "https://registry.npmjs.org/",
				"directory": "dist/npm",
				"access": "public",
				"provenance": true
			}
		]
	}
}
