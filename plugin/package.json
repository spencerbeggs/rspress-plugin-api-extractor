{
	"name": "rspress-plugin-api-extractor",
	"version": "0.2.2",
	"private": true,
	"description": "RSPress plugin for generating API documentation from TypeScript API Extractor models",
	"keywords": ["rspress", "plugin", "api-extractor", "documentation", "typescript"],
	"homepage": "https://github.com/spencerbeggs/rspress-plugin-api-extractor#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/rspress-plugin-api-extractor.git",
		"directory": "plugin"
	},
	"license": "MIT",
	"author": "Spencer Beggs",
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./runtime": "./src/runtime/index.tsx",
		"./tsconfig/rspress.json": "./public/tsconfig/rspress.json"
	},
	"scripts": {
		"build:dev": "node savvy.build.ts --target dev",
		"build:prod": "node savvy.build.ts --target prod",
		"prepare": "node savvy.build.ts --target dev",
		"types:check": "tsgo --noEmit"
	},
	"dependencies": {
		"@effect/platform": "catalog:silk",
		"@effect/platform-node": "catalog:silk",
		"@effect/sql": "catalog:silk",
		"@effect/sql-sqlite-node": "catalog:silk",
		"@microsoft/api-extractor-model": "^7.33.8",
		"@shikijs/twoslash": "^4.2.0",
		"api-extractor-llms": "0.1.0",
		"clsx": "^2.1.1",
		"effect": "catalog:silk",
		"gray-matter": "^4.0.3",
		"hast-util-to-jsx-runtime": "^2.3.6",
		"image-size": "^2.0.2",
		"mdast-util-from-markdown": "^2.0.3",
		"mdast-util-to-hast": "^13.2.1",
		"open": "^11.0.0",
		"prettier": "^3.8.4",
		"react-markdown": "^10.1.0",
		"semver-effect": "^0.2.1",
		"shiki": "^4.2.0",
		"type-registry-effect": "^1.0.0",
		"typescript": "catalog:silk",
		"unist-util-visit": "^5.1.0"
	},
	"devDependencies": {
		"@microsoft/tsdoc": "^0.16.0",
		"@rspress/core": "^2.0.14",
		"@savvy-web/rspress-builder": "^0.9.1",
		"@tsdown/css": "^0.22.2",
		"@types/hast": "^3.0.4",
		"@types/mdast": "^4.0.4",
		"@types/node": "catalog:silk",
		"@types/react": "catalog:silk",
		"@types/react-dom": "catalog:silk",
		"@types/unist": "^3.0.3",
		"@typescript/native-preview": "catalog:silk",
		"mdast-util-mdx-jsx": "^3.2.0",
		"react": "catalog:silk",
		"react-dom": "catalog:silk",
		"unified": "^11.0.5"
	},
	"peerDependencies": {
		"@rspress/core": "^2.0.0",
		"react": "catalog:silkPeers",
		"react-dom": "catalog:silkPeers"
	},
	"engines": {
		"node": ">=24.11.0"
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev/pkg",
		"linkDirectory": true,
		"targets": {
			"npm": true
		}
	}
}
