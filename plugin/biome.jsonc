{
	"$schema": "https://biomejs.dev/schemas15/schema.json",
	"extends": ["@savvy-web/silk/biome"],
	"root": false,
	"overrides": [
		{
			"includes": ["**/*.css", "**/runtime/**/*.tsx", "**/components/**/*.tsx"],
			"linter": {
				"rules": {
					"correctness": {
						"useImportExtensions": "off"
					}
				}
			}
		}
	]
}
