{
	"$schema": "https://json.schemastore.org/tsconfig.json",
	"compilerOptions": {
		"composite": true,
		"declaration": true,
		"jsx": "react-jsx",
		"module": "esnext",
		"moduleResolution": "bundler",
		"outDir": "./dist",
		"resolveJsonModule": true,
		"rootDir": "./src",
		"skipLibCheck": true,
		"strict": true,
		"strictNullChecks": true,
		"target": "es2023"
	},
	"exclude": ["node_modules", "dist"],
	"include": ["src/**/*.ts", "types/**/*.ts", "src/**/*.tsx", "src/**/*.mdx", "src/**/*.mts", "src/**/*.cts"]
}
